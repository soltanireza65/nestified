{
  "name": "nestified",
  "private": true,
  "scripts": {
    "test": "turbo run test",
    "build": "turbo run build",
    "publish": "turbo run publish",
    "publish:dev": "turbo run publish:dev",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "prettier": "^3.8.3",
    "@types/node": "^25.6.0",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "rimraf": "^6.1.3"
  }
}
